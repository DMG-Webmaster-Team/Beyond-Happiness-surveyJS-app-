# Database (required in production — set on your host/Docker, not only locally)
# Remote MySQL example:
# DATABASE_URL=mysql://user:password@your-db-host:3306/happiness_survey

DATABASE_URL=

# Or use individual variables:
# DB_HOST=your-db-host
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=happiness_survey

# Local MAMP development only (NODE_ENV=development):
# DATABASE_URL=mysql://root:root@localhost:3306/happiness_survey?socketPath=/Applications/MAMP/tmp/mysql/mysql.sock
# DB_SOCKET_PATH=/Applications/MAMP/tmp/mysql/mysql.sock
