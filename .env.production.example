# Copy to .env.production on the server (do not commit .env.production)

NODE_ENV=production
PORT=3000

# Required — remote MySQL (replace placeholders)
DATABASE_URL=mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/happiness_survey

# App URL (for emails/links if used)
BASE_URL=https://beyondhappiness-global.com

# Optional: SurveyJS license
# NEXT_PUBLIC_SURVEYJS_LICENSE_KEY=

# Optional: Mailgun (if sending email)
# MAILGUN_DOMAIN=
# MAILGUN_FROM=
# MAILGUN_API_URL=https://api.mailgun.net/v3
# MAILGUN_PRIVATE_API_KEY=
